{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZK Drive",
  "version": "0.1.0",
  "identifier": "com.zkdrive.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZK Drive",
        "width": 1024,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "id": "zk-drive-tray",
      "iconPath": "icons/128x128.png",
      "iconAsTemplate": true,
      "tooltip": "ZK Drive"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Secure document sync",
    "longDescription": "ZK Drive desktop sync client — keep your secure workspaces synced across devices.",
    "publisher": "ZK Drive",
    "copyright": "Copyright © ZK Drive"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kennguy3n/zk-drive/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IFJFUExBQ0UgV0lUSCBZT1VSIE1JTklTSUdOIFBVQkxJQyBLRVkK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
