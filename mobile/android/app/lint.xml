      generator's JNA-based cleaner fallback is used instead and the API-33 path is
      never reached. Scope the NewApi suppression to that single generated file only.
    -->
    <issue id="NewApi">
        <ignore regexp="uniffi/zk_mobile_bridge/zk_mobile_bridge\.kt" />
    </issue>
</lint>
