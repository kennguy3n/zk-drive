<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>You've been invited to ZK Drive</title>
  </head>
  <body style="font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;line-height:1.5;color:#1f2937;max-width:560px;margin:0 auto;padding:24px;">
    <h2 style="font-size:18px;margin:0 0 16px;">You've been invited to a folder on ZK Drive</h2>
    <p style="margin:0 0 16px;">
      <strong>{{.InviterName}}</strong> invited you to collaborate on a folder in
      <strong>{{.WorkspaceName}}</strong>.
    </p>
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px;font-size:14px;">
      <tr>
        <td style="padding:4px 16px 4px 0;color:#6b7280;">Folder</td>
        <td style="padding:4px 0;"><strong>{{.FolderName}}</strong></td>
      </tr>
      <tr>
        <td style="padding:4px 16px 4px 0;color:#6b7280;">Role</td>
        <td style="padding:4px 0;"><strong>{{.Role}}</strong></td>
      </tr>
      {{- if .ExpiresAt}}
      <tr>
        <td style="padding:4px 16px 4px 0;color:#6b7280;">Expires</td>
        <td style="padding:4px 0;"><strong>{{.ExpiresAt}}</strong></td>
      </tr>
      {{- end}}
    </table>
    <p style="margin:0 0 24px;">
      <a href="{{.AcceptURL}}" style="display:inline-block;background:#111827;color:#ffffff;text-decoration:none;padding:10px 16px;border-radius:6px;font-weight:600;">Accept invite</a>
    </p>
    <p style="margin:0 0 16px;font-size:13px;color:#4b5563;">
      Or copy and paste this link into your browser:<br />
      <a href="{{.AcceptURL}}" style="color:#2563eb;word-break:break-all;">{{.AcceptURL}}</a>
    </p>
    <p style="margin:0 0 16px;font-size:13px;color:#4b5563;">
      If you don't already have an account, you can sign up with this email address
      (<strong>{{.Email}}</strong>) at the link above.
    </p>
    <hr style="border:none;border-top:1px solid #e5e7eb;margin:24px 0;" />
    <p style="margin:0;font-size:12px;color:#6b7280;">
      You're receiving this email because someone shared a folder with you on ZK Drive.
      If you weren't expecting it, you can safely ignore this message — no action will be
      taken on your behalf.
    </p>
  </body>
</html>
